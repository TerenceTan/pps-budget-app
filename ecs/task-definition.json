{
  "family": "budget-flask",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::292828418386:role/ecsTaskExecutionRole",
  "taskRoleArn": "arn:aws:iam::292828418386:role/budget-flask-task-role",
  "containerDefinitions": [
    {
      "name": "budget-flask",
      "image": "292828418386.dkr.ecr.ap-southeast-1.amazonaws.com/budget-flask:latest",
      "portMappings": [
        {
          "containerPort": 8000,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "SHEET_ID",
          "value": "13TMeZ3pqdUQr2WRMG5G70xchZKfmiPVOShZChqbUsv4"
        },
        {
          "name": "BQ_PROJECT_ID",
          "value": "gen-lang-client-0602500310"
        },
        {
          "name": "BQ_DATASET",
          "value": "pepperstone_apac"
        },
        {
          "name": "BQ_TABLE",
          "value": "ad_performance"
        },
        {
          "name": "BQ_LOCATION",
          "value": "asia-southeast1"
        },
        {
          "name": "USE_POSTGRES",
          "value": "true"
        }
      ],
      "secrets": [
        {
          "name": "SECRET_KEY",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:292828418386:secret:budget-app/secret-key"
        },
        {
          "name": "GOOGLE_CREDS_JSON",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:292828418386:secret:budget-app/google-credentials"
        },
        {
          "name": "DATABASE_URL",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:292828418386:secret:budget-flask/database-url-FdC73X"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/budget-flask",
          "awslogs-region": "ap-southeast-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "essential": true
    }
  ]
}
