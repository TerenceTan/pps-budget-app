commands:
  01_fetch_google_credentials:
    command: |
      aws secretsmanager get-secret-value \
        --secret-id budget-app/google-credentials \
        --region ap-southeast-1 \
        --query SecretString \
        --output text > /etc/google-credentials.json
      chmod 600 /etc/google-credentials.json
      chown webapp:webapp /etc/google-credentials.json
    ignoreErrors: false
